# Server-side only. Never expose this value through VITE_* variables.
OPENAI_API_KEY=

# Hard safety gate. The SDK is never called unless this is literally true.
DREAMCRAFT_OPENAI_ENABLED=false

# Runtime aliases and strategy are allowlisted by server code.
OPENAI_RUNTIME_MODEL=gpt-5.6-sol
OPENAI_CORE_MODEL=gpt-5.6-terra
OPENAI_ENRICHMENT_MODEL=gpt-5.6-luna
DREAMCRAFT_GENERATION_STRATEGY=single-sol

# Suggested operational defaults; implementation may rename after documenting.
DREAMCRAFT_REQUEST_TIMEOUT_MS=12000
DREAMCRAFT_MAX_DREAM_CHARS=1200
DREAMCRAFT_MAX_BODY_BYTES=8192
DREAMCRAFT_ENABLE_DIRECTOR_PIPELINE=false
DREAMCRAFT_ENABLE_DEBUG_METRICS=false

# Optional public client configuration. Never put secrets in VITE_* variables.
VITE_DREAMCRAFT_API_BASE=/api
VITE_DREAMCRAFT_DEBUG=false
VITE_DREAMCRAFT_GENERATION_STRATEGY=single-sol
