{
  "name": "dreamcraft-3d",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "test:e2e": "playwright test",
    "test:performance:hardware": "DREAMCRAFT_REQUIRE_HARDWARE_PERFORMANCE=true playwright test tests/e2e/g6-performance.spec.ts tests/e2e/g6-performance-mobile.spec.ts",
    "test:pwa": "tsc --noEmit && vite build && playwright test --config playwright.pwa.config.ts",
    "eval": "vitest run tests/eval",
    "eval:dreams": "vitest run tests/eval",
    "smoke:deployed": "node scripts/smoke-deployed.mjs",
    "test:smoke-deployed": "node --test scripts/smoke-deployed.test.mjs",
    "validate:g3:live": "node scripts/validate-g3-live.mjs",
    "dreamlibrary:atlas": "node scripts/generate-dreamlibrary-atlas.mjs"
  },
  "dependencies": {
    "openai": "6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
